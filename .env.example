# ============================================================
# Trading Agent System — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Alpaca (paper trading — free at alpaca.markets) ---
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Finnhub (free at finnhub.io) ---
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- Alpha Vantage (free at alphavantage.co) ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- Reddit PRAW (free at reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=trading-agent-system/1.0

# --- Notifications (optional) ---
NTFY_TOPIC=trading-agent-system

# --- System ---
LOG_LEVEL=INFO
ENVIRONMENT=paper
REQUIRE_TRADE_APPROVAL=true

# --- LLM Backend (optional — replaces Claude for news synthesis) ---
# Option A: Groq (free tier at console.groq.com — recommended for testing)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# Option B: Ollama (local, free — install from ollama.ai, then: ollama pull llama3.1:8b)
# OLLAMA_ENABLED=true
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434
